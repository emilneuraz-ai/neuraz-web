---
// src/components/Footer.astro - Refined minimalist
---

<footer class="py-16 px-6 sm:px-12 lg:px-16 border-t border-white/5">
  <div class="max-w-7xl">
    <div class="grid md:grid-cols-4 gap-12 mb-16">
      <!-- Brand -->
      <div class="md:col-span-2">
        <p class="text-[18px] font-medium tracking-[-0.01em] text-white mb-4">Neuraz</p>
        
        <p class="text-[14px] font-normal leading-[1.6] text-white/40 max-w-sm mb-6">
          Inteligencia Artificial Aplicada. Diseñamos sistemas inteligentes 
          para crear, documentar y automatizar tu negocio.
        </p>

        <div class="flex gap-6">
          <a 
            href="#" 
            class="text-[12px] font-normal tracking-[0.05em] uppercase text-white/30 hover:text-white transition-colors duration-200"
          >
            LinkedIn
          </a>
          
          <a 
            href="#" 
            class="text-[12px] font-normal tracking-[0.05em] uppercase text-white/30 hover:text-white transition-colors duration-200"
          >
            GitHub
          </a>
        </div>
      </div>

      <!-- Links -->
      <div>
        <p class="text-[11px] font-normal tracking-[0.1em] uppercase text-white/30 mb-4">Servicios</p>
        <ul class="space-y-3">
          <li><a href="#servicios" class="text-[13px] font-normal text-white/50 hover:text-white transition-colors duration-200">Automatización</a></li>
          <li><a href="#servicios" class="text-[13px] font-normal text-white/50 hover:text-white transition-colors duration-200">Gamificación</a></li>
          <li><a href="#servicios" class="text-[13px] font-normal text-white/50 hover:text-white transition-colors duration-200">Inteligencia Artificial</a></li>
          <li><a href="#servicios" class="text-[13px] font-normal text-white/50 hover:text-white transition-colors duration-200">Documentación</a></li>
        </ul>
      </div>

      <div>
        <p class="text-[11px] font-normal tracking-[0.1em] uppercase text-white/30 mb-4">Empresa</p>
        <ul class="space-y-3">
          <li><a href="#nosotros" class="text-[13px] font-normal text-white/50 hover:text-white transition-colors duration-200">Sobre nosotros</a></li>
          <li><a href="#equipo" class="text-[13px] font-normal text-white/50 hover:text-white transition-colors duration-200">Equipo</a></li>
          <li><a href="#contacto" class="text-[13px] font-normal text-white/50 hover:text-white transition-colors duration-200">Contacto</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-[12px] font-normal text-white/30">
        © 2026 Neuraz. Todos los derechos reservados.
      </p>
      
      <p class="text-[12px] font-normal text-white/30">
        Hecho con cuidado.
      </p>
    </div>
  </div>
</footer>
