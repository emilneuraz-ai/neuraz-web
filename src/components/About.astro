---
// src/components/About.astro
---

<section id="nosotros" class="py-24 bg-dark-800 relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-primary-500/5 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Content -->
      <div>
        <span class="inline-block px-4 py-2 rounded-full bg-accent-500/10 border border-accent-500/20 text-accent-400 text-sm font-medium mb-6">
          Sobre Nosotros
        </span>

        <h2 class="text-4xl sm:text-5xl font-bold text-white mb-6">
          Facilitamos herramientas <span class="text-accent-400">tecnológicas</span> y educamos sobre su uso responsable
        </h2>

        <p class="text-gray-300 text-lg mb-8">
          No somos una empresa de software genérico ni vendemos soluciones enlatadas. 
          Diseñamos, construimos e implementamos herramientas digitales a medida, 
          pensadas para el contexto real de cada cliente.
        </p>

        <!-- Values -->
        <div class="space-y-6">
          <div class="flex items-start">
            <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-primary-500/10 flex items-center justify-center mr-4">
              <svg class="w-6 h-6 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <div>
              <h3 class="text-white font-semibold mb-1">Negocios reales</h3>
              <p class="text-gray-300 text-sm">Trabajamos con negocios reales, no con casos de laboratorio.</p>
            </div>
          </div>

          <div class="flex items-start">
            <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-accent-500/10 flex items-center justify-center mr-4">
              <svg class="w-6 h-6 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
              </svg>
            </div>
            <div>
              <h3 class="text-white font-semibold mb-1">Lenguaje simple</h3>
              <p class="text-gray-300 text-sm">Explicamos todo en lenguaje simple, sin tecnicismos innecesarios.</p>
            </div>
          </div>

          <div class="flex items-start">
            <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-primary-500/10 flex items-center justify-center mr-4">
              <svg class="w-6 h-6 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <div>
              <h3 class="text-white font-semibold mb-1">Soluciones duraderas</h3>
              <p class="text-gray-300 text-sm">Construimos cosas que duran y que el equipo puede usar sin depender de nosotros.</p>
            </div>
          </div>

          <div class="flex items-start">
            <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-accent-500/10 flex items-center justify-center mr-4">
              <svg class="w-6 h-6 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
            </div>
            <div>
              <h3 class="text-white font-semibold mb-1">Impacto real</h3>
              <p class="text-gray-300 text-sm">Nos importa el impacto real en el negocio, no solo entregar código.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Stats / Visual -->
      <div class="relative">
        <div class="grid grid-cols-2 gap-6">
          <div class="p-6 rounded-2xl bg-dark-700 border border-white/5">
            <div class="text-4xl font-bold text-primary-400 mb-2">6</div>
            <div class="text-gray-300 text-sm">Áreas de especialización</div>
          </div>

          <div class="p-6 rounded-2xl bg-dark-700 border border-white/5">
            <div class="text-4xl font-bold text-accent-400 mb-2">9</div>
            <div class="text-gray-300 text-sm">Servicios activos</div>
          </div>

          <div class="p-6 rounded-2xl bg-dark-700 border border-white/5">
            <div class="text-4xl font-bold text-primary-400 mb-2">24/7</div>
            <div class="text-gray-300 text-sm">Operación automática</div>
          </div>

          <div class="p-6 rounded-2xl bg-dark-700 border border-white/5">
            <div class="text-4xl font-bold text-accent-400 mb-2">+35%</div>
            <div class="text-gray-300 text-sm">Aumento ticket promedio</div>
          </div>
        </div>

        <!-- Specializations -->
        <div class="mt-8 p-6 rounded-2xl bg-gradient-to-br from-primary-500/10 to-accent-500/10 border border-primary-500/20">
          <h3 class="text-white font-semibold mb-4">Áreas de Especialización</h3>
          <div class="grid grid-cols-2 gap-3">
            <div class="flex items-center text-gray-300 text-sm">
              <span class="w-2 h-2 rounded-full bg-primary-400 mr-2"></span>
              Sistemas de fidelización
            </div>
            <div class="flex items-center text-gray-300 text-sm">
              <span class="w-2 h-2 rounded-full bg-accent-400 mr-2"></span>
              Automatización de procesos
            </div>
            <div class="flex items-center text-gray-300 text-sm">
              <span class="w-2 h-2 rounded-full bg-primary-400 mr-2"></span>
              Asistentes inteligentes
            </div>
            <div class="flex items-center text-gray-300 text-sm">
              <span class="w-2 h-2 rounded-full bg-accent-400 mr-2"></span>
              Gestión de documentos
            </div>
            <div class="flex items-center text-gray-300 text-sm">
              <span class="w-2 h-2 rounded-full bg-primary-400 mr-2"></span>
              Paneles de estadísticas
            </div>
            <div class="flex items-center text-gray-300 text-sm">
              <span class="w-2 h-2 rounded-full bg-accent-400 mr-2"></span>
              Generación de contenido
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
