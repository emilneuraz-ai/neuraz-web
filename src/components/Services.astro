---
// src/components/Services.astro - Minimalist version
import { services, categories } from '../data/services';

const categoryNumber: Record<string, string> = {
  'Automatización': '01',
  'Gamificación': '02',
  'Inteligencia Artificial': '03',
  'Documentación': '04',
  'Análisis de datos': '05',
};
---

<section id="servicios" class="py-32 px-6 sm:px-12 lg:px-24">
  <div class="max-w-6xl">
    <!-- Section header -->
    <div class="mb-24">
      <p class="text-label text-text-tertiary mb-4">Servicios</p>
      <h2 class="text-headline text-text-primary max-w-3xl">
        Soluciones que transforman tu negocio.
      </h2>
    </div>

    <!-- Services list -->
    <div class="space-y-0">
      {categories.map((category, catIndex) => {
        const categoryServices = services.filter(s => s.category === category);
        return (
          <div class="border-t border-white/10">
            <!-- Category header -->
            <div class="py-8 flex items-baseline justify-between">
              <div class="flex items-baseline gap-6">
                <span class="text-label text-text-tertiary">{categoryNumber[category]}</span>
                <h3 class="text-title text-text-primary">{category}</h3>
              </div>
              <span class="text-small text-text-tertiary">{categoryServices.length} servicios</span>
            </div>

            <!-- Services in category -->
            <div class="pb-12 space-y-6">
              {categoryServices.map(service => (
                <div class="group py-6 border-t border-white/5 first:border-t-0">
                  <div class="flex items-start justify-between gap-8">
                    <div class="flex-1">
                      <div class="flex items-center gap-4 mb-3">
                        <h4 class="text-title text-text-primary group-hover:text-accent transition-colors">
                          {service.name}
                        </h4>
                        {service.featured && (
                          <span class="text-label text-accent">Destacado</span>
                        )}
                      </div>
                      
                      <p class="text-body text-text-secondary max-w-2xl mb-4">
                        {service.description}
                      </p>
                      
                      <p class="text-small text-text-tertiary">
                        {service.benefit}
                      </p>
                    </div>
                    
                    <div class="hidden sm:flex flex-wrap gap-2 justify-end max-w-xs">
                      {service.industries.slice(0, 3).map(industry => (
                        <span class="text-small text-text-tertiary">{industry}</span>
                      ))}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
