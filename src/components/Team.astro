---
// src/components/Team.astro - Bauhaus minimal (fixed layout)
---

<section id="equipo" class="py-24 px-6 sm:px-8 bg-white">
  <div class="max-w-7xl mx-auto">
    
    <!-- Section header -->
    <div class="mb-16">
      <div class="mb-6">
        <span class="text-[10px] font-medium tracking-[0.2em] text-black/40 uppercase">Equipo</span>
      </div>

      <h2 class="text-[clamp(1.75rem,4vw,2.5rem)] font-light leading-[1.15] tracking-tight text-black mb-4">
        Así trabajamos.
        <span class="font-medium">Así somos.</span>
      </h2>
      
      <p class="text-base text-black/60 leading-relaxed max-w-lg">
        No somos un equipo grande, somos un equipo bueno. Combinamos formación 
        técnica sólida con una mirada creativa.
      </p>
    </div>

    <!-- Team grid -->
    <div class="grid md:grid-cols-2 gap-8 lg:gap-12">
      <!-- Emil -->
      <div class="flex gap-6">
        <div class="w-20 h-20 lg:w-24 lg:h-24 flex-shrink-0 overflow-hidden bg-black/5">
          <img 
            src="/images/team/emil.jpg" 
            alt="Emil Richardo González"
            class="w-full h-full object-cover grayscale"
            loading="lazy"
          />
        </div>
        
        <div class="flex-1 min-w-0">
          <h3 class="text-base lg:text-lg font-medium text-black mb-1">Emil R. González</h3>
          <p class="text-sm text-black mb-0.5">Diseñador y Desarrollador</p>
          <p class="text-xs text-black/40 mb-3">Web Developer</p>
          
          <a 
            href="https://www.behance.net/emilgonzalez" 
            target="_blank"
            rel="noopener"
            class="text-[11px] font-medium tracking-[0.1em] text-black/40 hover:text-black transition-colors uppercase"
          >
            Behance →
          </a>
        </div>
      </div>

      <!-- Romina -->
      <div class="flex gap-6">
        <div class="w-20 h-20 lg:w-24 lg:h-24 flex-shrink-0 overflow-hidden bg-black/5">
          <img 
            src="/images/team/romina.jpg" 
            alt="Romina Lescano"
            class="w-full h-full object-cover grayscale"
            loading="lazy"
          />
        </div>
        
        <div class="flex-1 min-w-0">
          <h3 class="text-base lg:text-lg font-medium text-black mb-1">Romina Lescano</h3>
          <p class="text-sm text-black mb-0.5">Desarrolladora Web</p>
          <p class="text-xs text-black/40 mb-3">Lic. en Sistemas</p>
          
          <a 
            href="https://www.linkedin.com/in/romina-lescano/" 
            target="_blank"
            rel="noopener"
            class="text-[11px] font-medium tracking-[0.1em] text-black/40 hover:text-black transition-colors uppercase"
          >
            LinkedIn →
          </a>
        </div>
      </div>
    </div>


  </div>
</section>
