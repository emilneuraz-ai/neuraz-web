---
// src/components/Brain3D.astro - Improved polygonal brain with Three.js
---

<div id="brain-container" class="w-full h-[350px] lg:h-[450px]"></div>

<script>
  if (typeof window !== 'undefined' && typeof document !== 'undefined') {
    import('three').then((THREE) => {
      const container = document.getElementById('brain-container');
      if (!container) return;

      // Scene setup
      const scene = new THREE.Scene();
      scene.background = null;

      const camera = new THREE.PerspectiveCamera(50, container.clientWidth / container.clientHeight, 0.1, 100);
      camera.position.set(0, 0, 14);

      const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
      renderer.setSize(container.clientWidth, container.clientHeight);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      container.appendChild(renderer.domElement);

      // Brain group
      const brainGroup = new THREE.Group();
      scene.add(brainGroup);

      // Materials
      const wireframeMaterial = new THREE.MeshBasicMaterial({
        color: 0x1a1a1a,
        wireframe: true,
        transparent: true,
        opacity: 0.6
      });

      const solidMaterial = new THREE.MeshBasicMaterial({
        color: 0xf5f5f5,
        transparent: true,
        opacity: 0.05
      });

      // Create a better hemisphere shape using sphere geometry
      function createHemisphere(xOffset, isLeft) {
        const hemisphereGroup = new THREE.Group();

        // Main hemisphere - sphere with low segments for polygonal look
        const sphereGeo = new THREE.SphereGeometry(2.2, 16, 12, 0, Math.PI);
        
        // Deform to make it more brain-like
        const positions = sphereGeo.attributes.position.array;
        for (let i = 0; i < positions.length; i += 3) {
          const x = positions[i];
          const y = positions[i + 1];
          const z = positions[i + 2];
          
          // Flatten bottom
          if (y < -1) {
            positions[i + 1] = y * 0.6;
          }
          
          // Add some irregularity
          const noise = Math.sin(x * 2) * Math.cos(y * 2) * 0.15;
          positions[i] = x + noise;
          positions[i + 2] = z + noise;
        }
        sphereGeo.computeVertexNormals();

        const wireMesh = new THREE.Mesh(sphereGeo, wireframeMaterial);
        const solidMesh = new THREE.Mesh(sphereGeo, solidMaterial);
        
        // Scale for brain proportions
        wireMesh.scale.set(1, 0.9, 1.3);
        solidMesh.scale.set(1, 0.9, 1.3);
        
        hemisphereGroup.add(wireMesh);
        hemisphereGroup.add(solidMesh);

        // Add gyri (folds) - elongated bumps
        const gyriCount = 8;
        for (let i = 0; i < gyriCount; i++) {
          const angle = (i / gyriCount) * Math.PI;
          const gyrosGeo = new THREE.CapsuleGeometry(0.35, 1.8, 4, 8);
          
          const gyrosWire = new THREE.Mesh(gyrosGeo, wireframeMaterial);
          const gyrosSolid = new THREE.Mesh(gyrosGeo, solidMaterial);
          
          // Position on surface
          const radius = 2;
          const x = Math.cos(angle) * radius * 0.8;
          const y = Math.sin(angle) * radius * 0.6;
          const z = 1.5;
          
          gyrosWire.position.set(x, y, z);
          gyrosSolid.position.set(x, y, z);
          
          // Rotate to follow surface
          gyrosWire.rotation.z = angle * 0.5;
          gyrosWire.rotation.x = 0.3;
          gyrosSolid.rotation.z = angle * 0.5;
          gyrosSolid.rotation.x = 0.3;
          
          hemisphereGroup.add(gyrosWire);
          hemisphereGroup.add(gyrosSolid);
        }

        // Position hemisphere
        hemisphereGroup.position.x = xOffset;
        
        // Rotate to face center
        if (isLeft) {
          hemisphereGroup.rotation.y = -Math.PI / 2;
        } else {
          hemisphereGroup.rotation.y = Math.PI / 2;
        }
        
        return hemisphereGroup;
      }

      // Create hemispheres
      const leftHemisphere = createHemisphere(-1.1, true);
      const rightHemisphere = createHemisphere(1.1, false);
      
      brainGroup.add(leftHemisphere);
      brainGroup.add(rightHemisphere);

      // Corpus callosum (connection between hemispheres)
      const corpusGeo = new THREE.CylinderGeometry(0.8, 0.8, 2.2, 12);
      corpusGeo.rotateZ(Math.PI / 2);
      const corpusWire = new THREE.Mesh(corpusGeo, wireframeMaterial);
      const corpusSolid = new THREE.Mesh(corpusGeo, solidMaterial);
      corpusWire.position.y = -0.5;
      corpusSolid.position.y = -0.5;
      brainGroup.add(corpusWire);
      brainGroup.add(corpusSolid);

      // Neural connections
      const connectionMaterial = new THREE.LineBasicMaterial({ 
        color: 0x1a1a1a, 
        transparent: true, 
        opacity: 0.3 
      });

      // Create curved connections
      for (let i = 0; i < 6; i++) {
        const y = 1.5 - i * 0.6;
        const curve = new THREE.QuadraticBezierCurve3(
          new THREE.Vector3(-0.8, y, 0.5),
          new THREE.Vector3(0, y + 0.3, 1.2),
          new THREE.Vector3(0.8, y, 0.5)
        );
        
        const points = curve.getPoints(20);
        const geometry = new THREE.BufferGeometry().setFromPoints(points);
        const line = new THREE.Line(geometry, connectionMaterial);
        brainGroup.add(line);
      }

      // Floating synaptic nodes
      const nodeGeometry = new THREE.IcosahedronGeometry(0.08, 0);
      const nodeMaterial = new THREE.MeshBasicMaterial({ color: 0x1a1a1a });

      for (let i = 0; i < 20; i++) {
        const node = new THREE.Mesh(nodeGeometry, nodeMaterial);
        
        // Position around brain
        const theta = Math.random() * Math.PI * 2;
        const phi = Math.acos(2 * Math.random() - 1);
        const radius = 3.5 + Math.random() * 1.5;
        
        node.position.x = radius * Math.sin(phi) * Math.cos(theta);
        node.position.y = radius * Math.sin(phi) * Math.sin(theta) * 0.6;
        node.position.z = radius * Math.cos(phi);
        
        node.userData = {
          initialPos: node.position.clone(),
          phase: Math.random() * Math.PI * 2,
          speed: 0.5 + Math.random() * 0.5
        };
        
        brainGroup.add(node);
      }

      // Animation
      let animationId;
      const clock = new THREE.Clock();

      function animate() {
        animationId = requestAnimationFrame(animate);
        
        const time = clock.getElapsedTime();
        
        // Smooth horizontal rotation
        brainGroup.rotation.y = time * 0.2;
        
        // Gentle floating
        brainGroup.position.y = Math.sin(time * 0.4) * 0.15;
        
        // Subtle tilt
        brainGroup.rotation.z = Math.sin(time * 0.15) * 0.03;
        
        // Animate nodes
        brainGroup.children.forEach(child => {
          if (child.userData && child.userData.initialPos) {
            const { initialPos, phase, speed } = child.userData;
            
            child.position.x = initialPos.x + Math.sin(time * speed + phase) * 0.2;
            child.position.y = initialPos.y + Math.cos(time * speed * 0.8 + phase) * 0.2;
            child.position.z = initialPos.z + Math.sin(time * speed * 0.6 + phase) * 0.2;
          }
        });

        renderer.render(scene, camera);
      }

      animate();

      // Handle resize
      function handleResize() {
        if (!container) return;
        
        camera.aspect = container.clientWidth / container.clientHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(container.clientWidth, container.clientHeight);
      }

      window.addEventListener('resize', handleResize);

      // Cleanup
      document.addEventListener('astro:before-swap', () => {
        cancelAnimationFrame(animationId);
        window.removeEventListener('resize', handleResize);
        renderer.dispose();
        if (container && renderer.domElement) {
          container.removeChild(renderer.domElement);
        }
      });
    });
  }
</script>
