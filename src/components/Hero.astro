---
// src/components/Hero.astro - Bauhaus minimal with 3D Brain
import Brain3D from './Brain3D.astro';
---

<section class="min-h-screen bg-[#fafafa] pt-32 pb-20 px-6 sm:px-8 relative">
  <div class="max-w-7xl mx-auto">
    <div class="grid lg:grid-cols-12 gap-8 lg:gap-12">
      
      <!-- Left column - Title -->
      <div class="lg:col-span-7">
        <!-- Eyebrow -->
        <div class="mb-12">
          <span class="text-[10px] font-medium tracking-[0.2em] text-black/40 uppercase">
            Inteligencia Artificial
          </span>
        </div>

        <!-- Main headline - larger -->
        <h1 class="text-[clamp(3.5rem,10vw,8rem)] font-bold leading-[0.95] tracking-[-0.04em] text-black mb-16">
          Diseñamos sistemas inteligentes
        </h1>

        <p class="text-lg font-normal text-black/50 leading-relaxed max-w-lg mb-16">
          No vendemos software genérico. Construimos herramientas digitales 
          a medida, pensadas para el contexto real de cada negocio.
        </p>

        <div class="flex items-center gap-8">
          <a 
            href="#servicios" 
            class="inline-flex items-center gap-4 text-sm font-medium text-black group"
          >
            <span class="w-12 h-12 bg-black rounded-full flex items-center justify-center text-white group-hover:bg-[#e63946] transition-colors">
              ↓
            </span>
            <span class="tracking-wide">Ver servicios</span>
          </a>
        </div>
      </div>

      <!-- Right column - Empty for visual balance -->
      <div class="lg:col-span-5"></div>
    </div>
  </div>


</section>
