---
// src/components/Hero.astro - Minimalist version
---

<section class="min-h-screen flex flex-col justify-center px-6 sm:px-12 lg:px-24 py-24">
  <div class="max-w-5xl">
    <!-- Label -->
    <p class="text-label text-text-tertiary mb-8">
      Neuraz — Inteligencia Artificial Aplicada
    </p>

    <!-- Main headline -->
    <h1 class="text-display text-text-primary mb-8">
      Diseñamos sistemas
      <br />
      <span class="text-text-secondary">inteligentes.</span>
    </h1>

    <!-- Description -->
    <p class="text-body text-text-secondary max-w-2xl mb-12">
      No vendemos software genérico. Construimos herramientas digitales 
      a medida, pensadas para el contexto real de cada negocio.
    </p>

    <!-- Actions -->
    <div class="flex flex-wrap items-center gap-8">
      <a 
        href="#contacto" 
        class="group inline-flex items-center gap-3 text-title text-text-primary hover:text-accent transition-colors"
      >
        <span>Iniciar proyecto</span>
        <span class="text-text-tertiary group-hover:translate-x-1 transition-transform">→</span>
      </a>
      
      <a 
        href="#servicios" 
        class="text-small text-text-tertiary hover:text-text-secondary transition-colors"
      >
        Ver servicios
      </a>
    </div>
  </div>

  <!-- Bottom info -->
  <div class="absolute bottom-12 left-6 sm:left-12 lg:left-24 right-6 sm:right-12 lg:right-24">
    <div class="divider-left mb-8"></div>
    
    <div class="flex flex-wrap justify-between items-end gap-8">
      <div class="flex gap-12">
        <div>
          <p class="text-label text-text-tertiary mb-2">Servicios</p>
          <p class="text-title text-text-primary">9</p>
        </div>
        
        <div>
          <p class="text-label text-text-tertiary mb-2">Operación</p>
          <p class="text-title text-text-primary">24/7</p>
        </div>
        
        <div>
          <p class="text-label text-text-tertiary mb-2">Impacto</p>
          <p class="text-title text-text-primary">+35%</p>
        </div>
      </div>
      
      <div class="text-right">
        <p class="text-small text-text-tertiary">
          Latinoamérica — Remoto
        </p>
      </div>
    </div>
  </div>
</section>
