---
// src/components/Footer.astro - Minimalist version
---

<footer class="py-16 px-6 sm:px-12 lg:px-24 border-t border-white/5">
  <div class="max-w-6xl">
    <div class="grid md:grid-cols-4 gap-12 mb-16">
      <!-- Brand -->
      <div class="md:col-span-2">
        <p class="text-title text-text-primary mb-4">Neuraz</p>
        
        <p class="text-small text-text-secondary max-w-sm mb-6">
          Inteligencia Artificial Aplicada. Diseñamos sistemas inteligentes 
          para crear, documentar y automatizar tu negocio.
        </p>

        <div class="flex gap-6">
          <a 
            href="#" 
            class="text-small text-text-tertiary hover:text-text-primary transition-colors"
            aria-label="LinkedIn"
          >
            LinkedIn
          </a>
          
          <a 
            href="#" 
            class="text-small text-text-tertiary hover:text-text-primary transition-colors"
            aria-label="GitHub"
          >
            GitHub
          </a>
        </div>
      </div>

      <!-- Links -->
      <div>
        <p class="text-label text-text-tertiary mb-4">Servicios</p>
        <ul class="space-y-2">
          <li><a href="#servicios" class="text-small text-text-secondary hover:text-text-primary transition-colors">Automatización</a></li>
          <li><a href="#servicios" class="text-small text-text-secondary hover:text-text-primary transition-colors">Gamificación</a></li>
          <li><a href="#servicios" class="text-small text-text-secondary hover:text-text-primary transition-colors">Inteligencia Artificial</a></li>
          <li><a href="#servicios" class="text-small text-text-secondary hover:text-text-primary transition-colors">Documentación</a></li>
          <li><a href="#servicios" class="text-small text-text-secondary hover:text-text-primary transition-colors">Análisis de datos</a></li>
        </ul>
      </div>

      <div>
        <p class="text-label text-text-tertiary mb-4">Empresa</p>
        <ul class="space-y-2">
          <li><a href="#nosotros" class="text-small text-text-secondary hover:text-text-primary transition-colors">Sobre nosotros</a></li>
          <li><a href="#equipo" class="text-small text-text-secondary hover:text-text-primary transition-colors">Equipo</a></li>
          <li><a href="#contacto" class="text-small text-text-secondary hover:text-text-primary transition-colors">Contacto</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-small text-text-tertiary">
        © 2026 Neuraz. Todos los derechos reservados.
      </p>
      
      <p class="text-small text-text-tertiary">
        Hecho con cuidado.
      </p>
    </div>
  </div>
</footer>
