---
// src/components/Services.astro - Refined with interactions
import { services, categories } from '../data/services';

const categoryNumber: Record<string, string> = {
  'Automatización': '01',
  'Gamificación': '02',
  'Inteligencia Artificial': '03',
  'Documentación': '04',
  'Análisis de datos': '05',
};
---

<section id="servicios" class="py-32 px-6 sm:px-12 lg:px-16">
  <div class="max-w-7xl">
    <!-- Section header -->
    <div class="grid lg:grid-cols-2 gap-16 mb-24">
      <div>
        <p class="text-[11px] font-normal tracking-[0.15em] uppercase text-white/40 mb-4">Servicios</p>
        <h2 class="text-[clamp(2rem,4vw,3rem)] font-light tracking-[-0.02em] leading-[1.15] text-white">
          Soluciones que transforman tu negocio.
        </h2>
      </div>
      
      <div class="lg:pt-8">
        <p class="text-[15px] font-normal leading-[1.7] text-white/50">
          No somos una empresa de software genérico. Diseñamos herramientas digitales 
          a medida, pensadas para el contexto real de cada cliente.
        </p>
      </div>
    </div>

    <!-- Services by category -->
    <div class="space-y-0">
      {categories.map((category, catIndex) => {
        const categoryServices = services.filter(s => s.category === category);
        return (
          <div class="border-t border-white/10 group/category">
            <!-- Category header -->
            <div class="py-10 flex items-baseline justify-between cursor-pointer">
              <div class="flex items-baseline gap-8">
                <span class="text-[11px] font-normal tracking-[0.1em] text-white/30 w-8">{categoryNumber[category]}</span>
                <h3 class="text-[20px] sm:text-[24px] font-normal tracking-[-0.01em] text-white group-hover/category:text-blue-400 transition-colors duration-300">{category}</h3>
              </div>
              <span class="text-[13px] font-normal text-white/30">{categoryServices.length} servicios</span>
            </div>

            <!-- Services list -->
            <div class="pb-12 space-y-0">
              {categoryServices.map((service, idx) => (
                <div class="group/service py-8 border-t border-white/5 first:border-t-0 hover:bg-white/[0.02] transition-colors duration-300 -mx-6 px-6 sm:-mx-12 sm:px-12 lg:-mx-16 lg:px-16"
                >
                  <div class="flex flex-col lg:flex-row lg:items-start justify-between gap-6">
                    <div class="flex-1 lg:max-w-2xl">
                      <div class="flex items-center gap-4 mb-4">
                        <h4 class="text-[17px] font-medium tracking-[-0.01em] text-white group-hover/service:text-blue-400 transition-colors duration-200">
                          {service.name}
                        </h4>
                        {service.featured && (
                          <span class="text-[10px] font-medium tracking-[0.1em] uppercase text-blue-400 px-2 py-1 border border-blue-400/30 rounded-full">Destacado</span>
                        )}
                      </div>
                      
                      <p class="text-[14px] font-normal leading-[1.6] text-white/50 mb-4">
                        {service.description}
                      </p>
                      
                      <p class="text-[13px] font-normal leading-[1.5] text-white/30 flex items-start gap-2">
                        <span class="text-blue-400/60">→</span>
                        <span>{service.benefit}</span>
                      </p>
                    </div>
                    
                    <div class="flex flex-wrap gap-3">
                      {service.industries.slice(0, 3).map(industry => (
                        <span class="text-[12px] font-normal text-white/30 px-3 py-1.5 border border-white/10 rounded-full hover:border-white/20 hover:text-white/50 transition-all duration-200 cursor-default">
                          {industry}
                        </span>
                      ))}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
