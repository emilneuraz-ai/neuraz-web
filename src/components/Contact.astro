---
// src/components/Contact.astro - Minimalist version
---

<section id="contacto" class="py-32 px-6 sm:px-12 lg:px-24 border-t border-white/5">
  <div class="max-w-6xl">
    <div class="grid lg:grid-cols-2 gap-24">
      <!-- Content -->
      <div>
        <p class="text-label text-text-tertiary mb-4">Contacto</p>
        
        <h2 class="text-headline text-text-primary mb-8">
          Empecemos tu proyecto.
        </h2>

        <p class="text-body text-text-secondary mb-12">
          ¿Tenés un proyecto en mente? Hablemos. Diseñamos soluciones a medida 
          para transformar tu negocio con inteligencia artificial.
        </p>

        <!-- Contact info -->
        <div class="space-y-8">
          <div>
            <p class="text-label text-text-tertiary mb-2">Email</p>
            <a 
              href="mailto:hola@neuraz.io" 
              class="text-title text-text-primary hover:text-accent transition-colors"
            >
              hola@neuraz.io
            </a>
          </div>

          <div>
            <p class="text-label text-text-tertiary mb-2">Ubicación</p>
            <p class="text-title text-text-primary">Latinoamérica — Remoto</p>
          </div>
        </div>
      </div>

      <!-- Contact form -->
      <div class="lg:pt-16">
        <form class="space-y-8" action="#" method="POST">
          <div class="grid sm:grid-cols-2 gap-8">
            <div>
              <label for="name" class="block text-label text-text-tertiary mb-3">Nombre</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required
                class="w-full px-0 py-3 bg-transparent border-0 border-b border-white/20 text-text-primary placeholder-text-tertiary focus:outline-none focus:border-accent transition-colors"
                placeholder="Tu nombre"
              />
            </div>

            <div>
              <label for="email" class="block text-label text-text-tertiary mb-3">Email</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required
                class="w-full px-0 py-3 bg-transparent border-0 border-b border-white/20 text-text-primary placeholder-text-tertiary focus:outline-none focus:border-accent transition-colors"
                placeholder="tu@email.com"
              />
            </div>
          </div>

          <div>
            <label for="company" class="block text-label text-text-tertiary mb-3">Empresa</label>
            <input 
              type="text" 
              id="company" 
              name="company"
              class="w-full px-0 py-3 bg-transparent border-0 border-b border-white/20 text-text-primary placeholder-text-tertiary focus:outline-none focus:border-accent transition-colors"
              placeholder="Nombre de tu empresa"
            />
          </div>

          <div>
            <label for="service" class="block text-label text-text-tertiary mb-3">Servicio de interés</label>
            <select 
              id="service" 
              name="service"
              class="w-full px-0 py-3 bg-transparent border-0 border-b border-white/20 text-text-primary focus:outline-none focus:border-accent transition-colors cursor-pointer"
            >
              <option value="" class="bg-dark-900">Seleccionar servicio...</option>
              <option value="automatizacion" class="bg-dark-900">Automatización de Flujos</option>
              <option value="crm" class="bg-dark-900">CRM con Atención Automática</option>
              <option value="fidelizacion" class="bg-dark-900">Sistema de Puntos y Fidelización</option>
              <option value="juegos" class="bg-dark-900">Juegos y Experiencias de Marca</option>
              <option value="contenido-ia" class="bg-dark-900">Generación de Contenido con IA</option>
              <option value="agentes" class="bg-dark-900">Agentes de IA</option>
              <option value="documentacion" class="bg-dark-900">Documentación Inteligente</option>
              <option value="capacitaciones" class="bg-dark-900">Capacitaciones</option>
              <option value="dashboards" class="bg-dark-900">Dashboards en Tiempo Real</option>
              <option value="otro" class="bg-dark-900">Otro proyecto</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-label text-text-tertiary mb-3">Mensaje</label>
            <textarea 
              id="message" 
              name="message" 
              rows={4}
              required
              class="w-full px-0 py-3 bg-transparent border-0 border-b border-white/20 text-text-primary placeholder-text-tertiary focus:outline-none focus:border-accent transition-colors resize-none"
              placeholder="Contanos sobre tu proyecto..."
            ></textarea>
          </div>

          <button 
            type="submit"
            class="group inline-flex items-center gap-3 text-title text-text-primary hover:text-accent transition-colors pt-4"
          >
            <span>Enviar mensaje</span>
            <span class="text-text-tertiary group-hover:translate-x-1 transition-transform">→</span>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
