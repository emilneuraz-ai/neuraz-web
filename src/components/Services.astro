---
// src/components/Services.astro - Auto-expand on scroll
import { services, categories } from '../data/services';
---

<section id="servicios" class="py-24 px-6 sm:px-8 bg-white">
  <div class="max-w-7xl mx-auto">
    
    <!-- Section header -->
    <div class="grid lg:grid-cols-12 gap-8 mb-12">
      <div class="lg:col-span-4">
        <div class="mb-4">
          <span class="text-[10px] font-medium tracking-[0.2em] text-black/40 uppercase">Servicios</span>
        </div>
      </div>
      
      <div class="lg:col-span-8">
        <h2 class="text-[clamp(2rem,5vw,3.5rem)] font-bold leading-[1.1] tracking-[-0.04em] text-black text-left">
          Soluciones que transforman tu negocio
        </h2>
      </div>
    </div>

    <!-- Services list -->
    <div class="space-y-0 border-t border-black/10">
      {services.map((service, index) => {
        const accentColors = ['bg-[#e63946]', 'bg-black', 'bg-[#ffb703]'];
        const accentColor = accentColors[index % 3];
        
        return (
          <div 
            class="service-item border-b border-black/10" 
            data-index={index}
          >
            <!-- Title row -->
            <div class="service-header py-6 flex items-center justify-between cursor-pointer group">
              <div class="flex items-center gap-4">
                <span class={`w-2 h-2 ${accentColor} rounded-full flex-shrink-0`}></span>
                <h3 class="text-lg font-medium text-black group-hover:text-black/70 transition-colors">
                  {service.name}
                </h3>
              </div>
              
              <svg class="service-arrow w-5 h-5 text-black/30 transform transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 6l6 6-6 6" stroke-linecap="square" stroke-linejoin="miter"/>
              </svg>
            </div>

            <!-- Expandable content -->
            <div class="service-content overflow-hidden transition-all duration-1000 ease-out"
            >
              <div class="py-8 pl-6">
                <p class="text-sm text-black/60 leading-relaxed mb-3 max-w-2xl">{service.description}</p>
                
                <p class="text-xs text-black/40 leading-relaxed mb-4 max-w-2xl">→ {service.benefit}</p>
                
                <div class="flex flex-wrap items-center gap-4">
                  {service.industries.slice(0, 3).map(industry => (
                    <span class="text-[10px] font-medium tracking-[0.1em] text-black/30 uppercase">
                      {industry}
                    </span>
                  ))}
                  
                  <a 
                    href={`/servicios/${service.slug}`} 
                    class="inline-flex items-center gap-1 text-xs font-medium text-[#e63946] hover:text-black transition-colors"
                  >
                    Saber más
                    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="square" stroke-linejoin="miter"/>
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<script>
  // Auto-expand services when centered in viewport
  const serviceItems = document.querySelectorAll('.service-item');
  const serviceContents = document.querySelectorAll('.service-content');
  const serviceArrows = document.querySelectorAll('.service-arrow');
  
  // Check if we should reopen a service from sessionStorage
  const lastOpenedService = sessionStorage.getItem('lastOpenedService');
  let expandedIndex = -1;
  
  if (lastOpenedService) {
    // Find the service index by slug
    serviceItems.forEach((item, index) => {
      const link = item.querySelector('a[href^="/servicios/"]');
      if (link && link.getAttribute('href').includes(lastOpenedService)) {
        expandedIndex = index;
      }
    });
    
    // Clear the stored service
    sessionStorage.removeItem('lastOpenedService');
    
    // If we found a match, expand it immediately
    if (expandedIndex !== -1) {
      serviceContents.forEach((content, index) => {
        if (index === expandedIndex) {
          content.style.maxHeight = content.scrollHeight + 'px';
          content.style.opacity = '1';
          serviceArrows[index].style.transform = 'rotate(180deg)';
        } else {
          content.style.maxHeight = '0px';
          content.style.opacity = '0';
          serviceArrows[index].style.transform = 'rotate(0deg)';
        }
      });
      
      // Scroll to the expanded service
      setTimeout(() => {
        serviceItems[expandedIndex].scrollIntoView({ behavior: 'smooth', block: 'center' });
      }, 100);
    }
  }
  
  function updateExpandedService() {
    const viewportCenter = window.innerHeight / 2;
    let closestIndex = -1;
    let closestDistance = Infinity;
    
    serviceItems.forEach((item, index) => {
      const rect = item.getBoundingClientRect();
      const itemCenter = rect.top + rect.height / 2;
      const distance = Math.abs(itemCenter - viewportCenter);
      
      if (distance < closestDistance) {
        closestDistance = distance;
        closestIndex = index;
      }
    });
    
    // Only expand if within reasonable distance (within viewport)
    if (closestDistance < window.innerHeight / 2 && closestIndex !== expandedIndex) {
      expandedIndex = closestIndex;
      
      serviceContents.forEach((content, index) => {
        if (index === expandedIndex) {
          content.style.maxHeight = content.scrollHeight + 'px';
          content.style.opacity = '1';
          serviceArrows[index].style.transform = 'rotate(180deg)';
        } else {
          content.style.maxHeight = '0px';
          content.style.opacity = '0';
          serviceArrows[index].style.transform = 'rotate(0deg)';
        }
      });
    }
  }
  
  // Update on scroll
  window.addEventListener('scroll', updateExpandedService, { passive: true });
  
  // Initial check
  updateExpandedService();
  
  // Also allow click to toggle
  document.querySelectorAll('.service-header').forEach((header, index) => {
    header.addEventListener('click', () => {
      if (expandedIndex === index) {
        // Collapse if already expanded
        expandedIndex = -1;
        serviceContents[index].style.maxHeight = '0px';
        serviceContents[index].style.opacity = '0';
        serviceArrows[index].style.transform = 'rotate(0deg)';
      } else {
        // Expand clicked
        expandedIndex = index;
        serviceContents.forEach((content, i) => {
          if (i === index) {
            content.style.maxHeight = content.scrollHeight + 'px';
            content.style.opacity = '1';
            serviceArrows[i].style.transform = 'rotate(180deg)';
          } else {
            content.style.maxHeight = '0px';
            content.style.opacity = '0';
            serviceArrows[i].style.transform = 'rotate(0deg)';
          }
        });
      }
    });
  });
</script>
