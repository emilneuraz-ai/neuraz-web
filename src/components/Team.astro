---
// src/components/Team.astro - Minimalist version
---

<section id="equipo" class="py-32 px-6 sm:px-12 lg:px-24 border-t border-white/5">
  <div class="max-w-6xl">
    <!-- Section header -->
    <div class="mb-24">
      <p class="text-label text-text-tertiary mb-4">Equipo</p>
      <h2 class="text-headline text-text-primary max-w-3xl">
        Expertos en IA aplicada.
      </h2>
    </div>

    <!-- Team grid -->
    <div class="grid md:grid-cols-3 gap-px bg-white/10">
      <!-- Team member 1 -->
      <div class="bg-dark-900 p-8 sm:p-12">
        <div class="mb-8">
          <span class="text-display text-text-primary">E</span>
        </div>
        <h3 class="text-title text-text-primary mb-2">Emil González</h3>
        <p class="text-small text-accent mb-4">Fundador & CEO</p>
        
        <p class="text-small text-text-secondary">
          Especialista en IA aplicada y automatización de procesos de negocio.
        </p>
      </div>

      <!-- Team member 2 -->
      <div class="bg-dark-900 p-8 sm:p-12">
        <div class="mb-8">
          <span class="text-display text-text-primary">N</span>
        </div>
        
        <h3 class="text-title text-text-primary mb-2">Neury</h3>
        <p class="text-small text-accent mb-4">Asistente Virtual</p>
        
        <p class="text-small text-text-secondary">
          IA especializada en desarrollo de proyectos y gestión técnica.
        </p>
      </div>

      <!-- Join us -->
      <div class="bg-dark-900 p-8 sm:p-12 flex flex-col justify-between">
        <div>
          <div class="mb-8">
            <span class="text-display text-text-tertiary">+</span>
          </div>
          
          <h3 class="text-title text-text-primary mb-2">¿Querés sumarte?</h3>
          
          <p class="text-small text-text-secondary mb-8">
            Siempre estamos buscando talento apasionado por la IA.
          </p>
        </div>
        
        <a 
          href="#contacto" 
          class="inline-flex items-center gap-2 text-small text-text-primary hover:text-accent transition-colors group"
        >
          <span>Contactar</span>
          <span class="text-text-tertiary group-hover:translate-x-1 transition-transform">→</span>
        </a>
      </div>
    </div>
  </div>
</section>
